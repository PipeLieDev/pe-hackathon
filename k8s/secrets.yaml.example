# Copy this file to secrets.yaml and update the base64-encoded values.
# Do NOT commit secrets.yaml to version control.
#
# To base64 encode a value:
#   echo -n 'your-password' | base64
#
apiVersion: v1
kind: Secret
metadata:
  name: db-credentials
  namespace: url-shortener
type: kubernetes.io/basic-auth
data:
  username: cG9zdGdyZXM=      # "postgres" — the DB superuser
  password: cG9zdGdyZXM=      # "postgres" — change this!
  DATABASE_PASSWORD: cG9zdGdyZXM=  # must match password above (used by app envFrom)
