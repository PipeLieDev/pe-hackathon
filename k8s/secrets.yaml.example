# Copy this file to secrets.yaml and update the base64-encoded values.
# Do NOT commit secrets.yaml to version control.
#
# To base64 encode a value:
#   echo -n 'your-password' | base64
#
apiVersion: v1
kind: Secret
metadata:
  name: db-credentials
  namespace: url-shortener
type: Opaque
data:
  DATABASE_PASSWORD: cG9zdGdyZXM=  # "postgres" — change this!
  POSTGRES_PASSWORD: cG9zdGdyZXM=  # must match DATABASE_PASSWORD
